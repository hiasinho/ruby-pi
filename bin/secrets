#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks is not installed" >&2
  echo "install it from https://github.com/gitleaks/gitleaks" >&2
  exit 1
fi

if [ "${1:-}" = "--staged" ]; then
  exec gitleaks git --staged --no-banner
fi

exec gitleaks git --no-banner
